              <calculation class='tableau' formula='IF SUM([Calculation_225742942703046670]) = WINDOW_MAX(SUM([Calculation_225742942703046670]))&#13;&#10;then SUM([Calculation_225742942703046670])&#13;&#10;ELSEIF SUM([Calculation_225742942703046670]) = WINDOW_MIN(SUM([Calculation_225742942703046670]))&#13;&#10;then SUM([Calculation_225742942703046670])&#13;&#10;END'>
