          <datasource-dependencies datasource='federated.1eimdo01lo576t0zqxm8j1nump3d'>
            <column caption='PY Profit' datatype='real' default-format='n&quot;$&quot;0,K;-&quot;$&quot;0,K' name='[CY Profit (copy)_225742942703267855]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='IF YEAR([Order Date]) = [Parameters].[Parameter 1]-1 then [Profit]&#13;&#10;END' />
