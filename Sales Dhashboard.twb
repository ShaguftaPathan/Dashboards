            <column caption='CY Profit' datatype='real' default-format='n&quot;$&quot;0,K;-&quot;$&quot;0,K' name='[Calculation_225742942703046670]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='IF YEAR([Order Date]) = [Parameters].[Parameter 1] then [Profit]&#13;&#10;END' />
            </column>
            <column caption='% Diff Profit' datatype='real' default-format='p0.0%' name='[Calculation_225742942704005136]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='(SUM([Calculation_225742942703046670]) - SUM([CY Profit (copy)_225742942703267855]))/SUM([CY Profit (copy)_225742942703267855])' />
