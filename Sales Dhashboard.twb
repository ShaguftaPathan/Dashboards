            <column caption='{SUM([CY Profit])}' datatype='real' default-format='n&quot;$&quot;#,##0,K;-&quot;$&quot;#,##0,K' name='[Calculation_225742942809964572]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='{SUM([Calculation_225742942703046670])}' />
