          <datasource-dependencies datasource='federated.1eimdo01lo576t0zqxm8j1nump3d'>
            <column caption='PY Sales' datatype='real' default-format='n#,##0,K;-#,##0,K' name='[CY Sales (copy)_225742942671310850]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='IF YEAR([Order Date]) = [Parameters].[Parameter 1]-1 then [Sales]&#13;&#10;END' />
            </column>
            <column caption='CY Sales' datatype='real' default-format='n&quot;$&quot;#,##0,K;-&quot;$&quot;#,##0,K' name='[Calculation_225742942671069185]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='IF YEAR([Order Date]) = [Parameters].[Parameter 1] then [Sales]&#13;&#10;END' />
            </column>
            <column caption='% Diff Sales' datatype='real' default-format='p0.0%' name='[Calculation_225742942673641476]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='(SUM([Calculation_225742942671069185]) - SUM([CY Sales (copy)_225742942671310850])) / SUM([CY Sales (copy)_225742942671310850])' />
            </column>
            <column caption='Min/Max Sales' datatype='real' default-format='c&quot;$&quot;#,##0,K;(&quot;$&quot;#,##0,K)' name='[Calculation_225742942679130117]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='IF SUM([Calculation_225742942671069185]) = WINDOW_MAX(SUM([Calculation_225742942671069185]))&#13;&#10;then SUM([Calculation_225742942671069185])&#13;&#10;ELSEIF SUM([Calculation_225742942671069185]) = WINDOW_MIN(SUM([Calculation_225742942671069185]))&#13;&#10;then SUM([Calculation_225742942671069185])&#13;&#10;END'>
